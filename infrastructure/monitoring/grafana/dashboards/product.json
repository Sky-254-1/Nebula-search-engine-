{
  "__inputs": [],
  "__requires": [],
  "title": "Nebula Product Dashboard",
  "uid": "nebula-product",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["nebula", "product"],
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Active Users (DAU)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count by (user_id) (nebula_user_activity_total{period=\"24h\"}))",
          "legendFormat": "DAU",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Users (MAU)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count by (user_id) (nebula_user_activity_total{period=\"720h\"}))",
          "legendFormat": "MAU",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 4,
      "title": "DAU/MAU Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.4 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count by (user_id) (nebula_user_activity_total{period=\"24h\"})) / sum(count by (user_id) (nebula_user_activity_total{period=\"720h\"}))",
          "legendFormat": "DAU/MAU",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 5,
      "title": "Signup Conversion Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nebula_signups_total[7d])) / sum(rate(nebula_visits_total[7d])) * 100",
          "legendFormat": "Signup Conversion",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nebula_users_total",
          "legendFormat": "Total Users",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 7,
      "title": "Retention (Day 1 / Day 7 / Day 30)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nebula_retention_rate{cohort=\"d1\"} * 100",
          "legendFormat": "D1",
          "interval": "1m"
        },
        {
          "expr": "nebula_retention_rate{cohort=\"d7\"} * 100",
          "legendFormat": "D7",
          "interval": "1m"
        },
        {
          "expr": "nebula_retention_rate{cohort=\"d30\"} * 100",
          "legendFormat": "D30",
          "interval": "1m"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "panels": [],
      "title": "Search & AI Usage Trends",
      "type": "row"
    },
    {
      "id": 9,
      "title": "Search Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (type) (increase(nebula_search_requests_total[24h]))",
          "legendFormat": "{{ type }}",
          "interval": "1m"
        },
        {
          "expr": "sum(increase(nebula_search_requests_total[24h]))",
          "legendFormat": "Total",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 10,
      "title": "AI Answer Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nebula_ai_requests_total{status=\"success\"}[5m])) / sum(rate(nebula_ai_requests_total[5m])) * 100",
          "legendFormat": "AI Answer Success Rate",
          "interval": "1m"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 11,
      "panels": [],
      "title": "User Acquisition & Engagement",
      "type": "row"
    },
    {
      "id": 12,
      "title": "Signup Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(nebula_signups_total[24h])",
          "legendFormat": "Daily Signups",
          "interval": "1m"
        },
        {
          "expr": "rate(nebula_signups_total[1h])",
          "legendFormat": "Signups per hour",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 13,
      "title": "Retention Curve",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nebula_retention_rate * 100",
          "legendFormat": "{{ cohort }}",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 14,
      "title": "Searches Per User (Daily)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(nebula_search_requests_total[24h])) / sum(count by (user_id) (nebula_user_activity_total{period=\"24h\"}))",
          "legendFormat": "Searches / User / Day",
          "interval": "1m"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 15,
      "panels": [],
      "title": "Top Content & Queries",
      "type": "row"
    },
    {
      "id": 16,
      "title": "Top Search Queries",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [],
        "showTypeIcons": false
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.align", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(20, sum by (query) (increase(nebula_search_queries_total[7d])))",
          "legendFormat": "__auto",
          "format": "table",
          "instant": true,
          "interval": "1m"
        }
      ]
    },
    {
      "id": 17,
      "title": "Popular Search Backends",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": true
        },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (backend) (increase(nebula_search_requests_total{type=\"web\"}[7d]))",
          "legendFormat": "{{ backend }}",
          "interval": "1m"
        }
      ]
    },
    {
      "id": 18,
      "title": "AI Provider Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": true
        },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (provider) (increase(nebula_ai_requests_total[7d]))",
          "legendFormat": "{{ provider }}",
          "interval": "1m"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 19,
      "panels": [],
      "title": "User Activity Heatmap",
      "type": "row"
    },
    {
      "id": 20,
      "title": "Hourly User Activity (24h)",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "#b877d9",
          "max": null,
          "min": null,
          "mode": "scheme",
          "reverse": false,
          "scale": "linear",
          "scheme": "Spectral",
          "steps": 64
        },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single" },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "short" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (hour) (increase(nebula_user_activity_total{period=\"24h\"}[1h]))",
          "interval": "1h",
          "format": "heatmap"
        }
      ]
    }
  ]
}
