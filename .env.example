# Nebula Search — root environment template
# Copy to backend/.env and adjust values.

DATABASE_URL=nebula.db
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY_HOURS=24

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

BRAVE_API_KEY=
SERPAPI_KEY=

REDIS_URL=
RATE_LIMIT_PER_MINUTE=60
APP_ENV=development

# Comma-separated origins, or * for development only
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500
