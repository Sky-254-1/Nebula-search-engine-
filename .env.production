# ============================================================================
# Nebula Search Engine — Production Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your deployment.
# cp .env.production .env
# ============================================================================

# --- Application ---
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# --- Security: JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING_MINIMUM_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
JWT_EXPIRY_HOURS=24
JWT_ISSUER=Nebula Search
JWT_AUDIENCE=nebula-search-api
REFRESH_TOKEN_DAYS=30

# --- Security: Encryption ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# --- Security: CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://search.nebula-search.com,https://app.nebula-search.com

# --- Security: CSP (Content Security Policy) ---
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_CONNECT_SRC='self' https: wss:
CSP_FONT_SRC='self' data:
CSP_FRAME_SRC='none'
CSP_OBJECT_SRC='none'

# --- Security: Rate Limiting ---
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_TIER_BASIC=30
RATE_LIMIT_TIER_PRO=120
RATE_LIMIT_TIER_ENTERPRISE=600
RATE_LIMIT_BURST_MULTIPLIER=2
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
SIGNUP_RATE_LIMIT=5
LOGIN_RATE_LIMIT=5
REFRESH_RATE_LIMIT=10

# --- Security: Auth Settings ---
AUTH_COOKIE_MODE=true
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
ENABLE_RBAC=true
ENABLE_REFRESH_REUSE_DETECTION=true
ENABLE_AUDIT_LOGS=true

# --- Security: Feature Flags ---
ENABLE_CSRF=true
ENABLE_2FA=false
ENABLE_WEBAUTHN=false
REQUIRE_EMAIL_VERIFICATION=false

# --- Database ---
# PostgreSQL (production):
DATABASE_URL=postgresql://nebula:YOUR_DB_PASSWORD@nebula-db:5432/nebula_search
# SQLite (development/testing):
# DATABASE_URL=nebula.db

# --- Redis ---
# Required for multi-instance production deployments
REDIS_URL=redis://nebula-redis:6379/0

# --- Cache ---
CACHE_TTL_SECONDS=300

# --- Storage ---
STORAGE_ROOT=/data/storage

# --- AI Providers ---
# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo-preview
# AI_PROVIDER=openai

# Ollama (local)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2
# AI_PROVIDER=ollama

# Brave Search API
# BRAVE_API_KEY=...

# SerpAPI
# SERPAPI_KEY=...

# --- Crawler Settings ---
CRAWLER_USER_AGENT=NebulaSearch/1.0
CRAWLER_MAX_CONCURRENCY=10
CRAWLER_DEFAULT_DELAY=1.0
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES_PER_JOB=100
CRAWLER_ROBOTS_TTL=86400

# --- Indexing System ---
INDEXING_MAX_QUEUE_SIZE=10000
INDEXING_WORKER_COUNT=2
INDEXING_MAX_RETRIES=5
INDEXING_RETRY_BASE_DELAY=5.0
INDEXING_RETRY_BACKOFF_MULTIPLIER=3.0
INDEXING_CHUNK_SIZE=1000
INDEXING_CHUNK_OVERLAP=200

# --- Observability: Sentry ---
# SENTRY_DSN=https://...

# --- Observability: OpenTelemetry ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=nebula-search

# --- Email / SMTP ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxx
# SMTP_FROM_EMAIL=noreply@nebula-search.com
# SMTP_FROM_NAME=Nebula Search
# SMTP_USE_TLS=true
# EMAIL_VERIFICATION_EXPIRY_HOURS=24

# --- OAuth2 / SSO ---
# GOOGLE_OAUTH2_CLIENT_ID=...
# GOOGLE_OAUTH2_CLIENT_SECRET=...
# GITHUB_OAUTH2_CLIENT_ID=...
# GITHUB_OAUTH2_CLIENT_SECRET=...
# OAUTH2_REDIRECT_BASE_URI=https://api.nebula-search.com/api/v1/auth/oauth2
# OAUTH2_FRONTEND_REDIRECT_URI=https://app.nebula-search.com/oauth/callback

# --- API Key Settings ---
API_KEY_LENGTH=32
API_KEY_PREFIX=nb_

# --- Backup ---
# BACKUP_PROVIDER=s3
# S3_BUCKET=nebula-backups
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AZURE_STORAGE_CONNECTION_STRING=...
# AZURE_CONTAINER=nebula-backups
# BACKUP_RETENTION_DAYS=30

# --- Cross-Origin Headers ---
CROSS_ORIGIN_EMBEDDER_POLICY=require-corp
CROSS_ORIGIN_OPENER_POLICY=same-origin
CROSS_ORIGIN_RESOURCE_POLICY=same-origin
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()