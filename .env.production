# Nebula Search Engine - Production Environment Variables
# IMPORTANT: Never commit this file to version control
# Generate strong secrets using: openssl rand -hex 32

# PostgreSQL Configuration
POSTGRES_USER=nebula
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=nebula
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# MinIO Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=https://nebula-search.example.com

# Backend Configuration
BACKEND_PORT=8000
APP_ENV=production
LOG_LEVEL=info
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434
STORAGE_BACKEND=local
WORKERS_PER_CORE=1
MAX_WORKERS=4

# Frontend Configuration
FRONTEND_PORT=3000
CORS_ORIGINS=https://nebula-search.example.com

# Nginx Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
DOMAIN_NAME=nebula-search.example.com
SSL_EMAIL=admin@example.com

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=https://grafana.nebula-search.example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# SMTP Configuration (Optional)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=
SMTP_PASSWORD=

# Security
SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
ENCRYPTION_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_32_CHARS