# =============================================================================
# SECTION 1: INFRASTRUCTURE OVERVIEW
# =============================================================================
#
# Production Architecture:
#
# ┌──────────────────────────────────────────────────────────────────┐
# │                        Kubernetes Cluster                        │
# │                                                                  │
# │  ┌──────────┐  ┌──────────┐  ┌────────────┐  ┌──────────────┐  │
# │  │ Backend  │  │ Frontend │  │   Vector   │  │  Crawler     │  │
# │  │ HPA:2-10 │  │ HPA:2-8  │  │  Worker    │  │  Scheduler   │  │
# │  │ 512Mi    │  │ 256Mi    │  │  HPA:1-5   │  │  DaemonSet   │  │
# │  └────┬─────┘  └────┬─────┘  └─────┬──────┘  └──────┬───────┘  │
# │       │              │              │                │          │
# │  ┌────▼──────────────▼──────────────▼────────────────▼──────┐   │
# │  │                     Service Mesh (Istio)                   │   │
# │  └───────────────────────────────────────────────────────────┘   │
# │       │              │              │                            │
# │  ┌────▼──────────────▼──────────────▼───────────────────────┐   │
# │  │             PostgreSQL (Primary + Replica)                  │   │
# │  │             Redis Cluster (3 nodes)                         │   │
# │  └───────────────────────────────────────────────────────────┘   │
# └──────────────────────────────────────────────────────────────────┘
#
# Monitoring:
#   Prometheus + Grafana + Loki + Alertmanager + Jaeger (tracing)

# =============================================================================
# SECTION 2: DEPLOYMENT PROCEDURES
# =============================================================================

# --- 2.1 Standard Deployment ---
deploy_standard() {
    echo "[1/5] Running pre-deployment validation..."
    python scripts/validate_production.py || exit 1

    echo "[2/5] Running database migrations..."
    kubectl exec -n nebula-production deployment/backend -- python -m app.database.migrate

    echo "[3/5] Updating container images..."
    kubectl set image deployment/backend \
        backend=ghcr.io/sky-254-1/nebula-backend:${VERSION} \
        -n nebula-production

    echo "[4/5] Performing rolling update..."
    kubectl rollout status deployment/backend -n nebula-production --timeout=300s
    kubectl rollout status deployment/frontend -n nebula-production --timeout=300s

    echo "[5/5] Running post-deployment smoke tests..."
    curl -f https://api.nebula-search.com/health || exit 1
    echo "Deployment complete!"
}

# --- 2.2 Blue-Green Deployment ---
deploy_blue_green() {
    echo "[1/4] Deploying green environment..."
    kubectl apply -f infrastructure/k8s/green/

    echo "[2/4] Running green validation..."
    kubectl wait --for=condition=available deployment/backend-green -n nebula-production --timeout=300s

    echo "[3/4] Switching traffic to green..."
    kubectl patch service nebula-backend -n nebula-production \
        -p '{"spec":{"selector":{"version":"green"}}}'

    echo "[4/4] Blue environment ready for rollback..."
    echo "Blue still available at: kubectl get deployment/backend-blue -n nebula-production"
}

# --- 2.3 Canary Deployment ---
deploy_canary() {
    echo "[1/3] Deploying canary (10% traffic)..."
    kubectl apply -f infrastructure/k8s/canary/

    echo "[2/3] Monitoring canary for 5 minutes..."
    for i in $(seq 1 30); do
        ERROR_RATE=$(curl -s https://api.nebula-search.com/metrics | grep "nebula_http_requests_total{status=~\"5.*\"}" | awk '{print $2}')
        if [ "${ERROR_RATE:-0}" -gt "1" ]; then
            echo "Error rate too high! Rolling back canary..."
            kubectl delete -f infrastructure/k8s/canary/
            exit 1
        fi
        sleep 10
    done

    echo "[3/3] Promoting canary to full deployment..."
    kubectl rollout resume deployment/backend -n nebula-production
}

# =============================================================================
# SECTION 3: INCIDENT RESPONSE
# =============================================================================

# --- 3.1 Rollback Procedure ---
rollback() {
    local REVISION="${1:-1}"
    echo "Rolling back to revision ${REVISION}..."
    kubectl rollout undo deployment/backend -n nebula-production --to-revision=${REVISION}
    kubectl rollout status deployment/backend -n nebula-production --timeout=300s
}

# --- 3.2 Database Recovery ---
recover_database() {
    local BACKUP_FILE="$1"
    echo "Restoring database from backup: ${BACKUP_FILE}"
    kubectl exec -n nebula-production deployment/backend -- \
        python scripts/cloud_backup.py --restore ${BACKUP_FILE}
}

# --- 3.3 Pod Restart Sequence ---
restart_services() {
    echo "Restarting in dependency order..."
    kubectl rollout restart deployment/redis -n nebula-production
    kubectl rollout status deployment/redis -n nebula-production --timeout=120s

    kubectl rollout restart deployment/postgres -n nebula-production
    kubectl rollout status deployment/postgres -n nebula-production --timeout=120s

    kubectl rollout restart deployment/backend -n nebula-production
    kubectl rollout status deployment/backend -n nebula-production --timeout=300s

    kubectl rollout restart deployment/vector-worker -n nebula-production
    kubectl rollout status deployment/vector-worker -n nebula-production --timeout=120s

    kubectl rollout restart deployment/frontend -n nebula-production
    kubectl rollout status deployment/frontend -n nebula-production --timeout=120s
}

# =============================================================================
# SECTION 4: MONITORING & ALERTS
# =============================================================================

setup_alerts() {
    echo "Configuring production alerts..."
    kubectl apply -f infra/prometheus-alerts.yml
    kubectl apply -f infra/alertmanager.yml
}

alert_rules() {
    cat << 'EOF'
Production Alert Rules (infra/prometheus-alerts.yml):

CRITICAL (PagerDuty):
  - HighErrorRate: error_rate > 5% for 5m
  - HighLatency: p99_latency > 5s for 5m
  - ServiceDown: up == 0 for 1m
  - DatabaseConnectionPoolExhausted: db_connections > 80% for 5m

WARNING (Email/Slack):
  - Elevated4xxRate: 4xx_rate > 10% for 5m
  - HighCpuUsage: cpu_usage > 80% for 10m
  - HighMemoryUsage: memory_usage > 85% for 10m
  - CacheHitRateLow: cache_hit_ratio < 0.5 for 10m
  - DiskSpaceLow: disk_usage > 85% for 5m
EOF
}

# =============================================================================
# SECTION 5: PERFORMANCE BENCHMARKS
# =============================================================================

run_benchmarks() {
    echo "Running production benchmarks..."

    # 1. API Latency Test
    echo "[1/4] API Latency..."
    for endpoint in "/health" "/api/v1/search?q=test" "/api/v1/autocomplete?q=py"; do
        TOTAL=0
        for i in $(seq 1 10); do
            START=$(date +%s%N)
            curl -so /dev/null -w "%{http_code}" "https://api.nebula-search.com${endpoint}"
            END=$(date +%s%N)
            TOTAL=$((TOTAL + (END - START)))
        done
        AVG=$((TOTAL / 10 / 1000000))
        echo "  ${endpoint}: avg ${AVG}ms"
    done

    # 2. Load Test
    echo "[2/4] Load Test (100 users, 5 min)..."
    locust -f tests/load/locustfile.py \
        --host=https://api.nebula-search.com \
        --users 100 --spawn-rate 10 \
        --run-time 5m --headless --only-summary

    # 3. Database Query Performance
    echo "[3/4] Database Query Performance..."
    kubectl exec -n nebula-production deployment/backend -- python -c "
import asyncio
from app.database.engine import connect
async def test():
    db = await connect()
    start = asyncio.get_event_loop().time()
    for _ in range(100):
        await db.execute('SELECT 1')
    elapsed = asyncio.get_event_loop().time() - start
    print(f'100 queries: {elapsed:.2f}s (avg {(elapsed/100)*1000:.2f}ms)')
    await db.close()
asyncio.run(test())
"

    # 4. Cache Performance
    echo "[4/4] Cache Hit Ratio..."
    curl -s https://api.nebula-search.com/metrics | grep "nebula_cache"
}

# =============================================================================
# SECTION 6: BACKUP & DR PROCEDURES
# =============================================================================

# --- 6.1 Scheduled Backup (CronJob) ---
backup_cronjob() {
    cat << 'EOF'
apiVersion: batch/v1
kind: CronJob
metadata:
  name: nebula-backup
  namespace: nebula-production
spec:
  schedule: "0 2 * * *"  # Daily at 2 AM
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: backup
            image: ghcr.io/sky-254-1/nebula-backend:latest
            command:
            - python
            - scripts/cloud_backup.py
            - --backup
          restartPolicy: OnFailure
EOF
}

# --- 6.2 DR Test Procedure ---
dr_test() {
    echo "===== DISASTER RECOVERY TEST ====="
    echo "[1/5] Verifying backup integrity..."
    python scripts/cloud_backup.py --list

    echo "[2/5] Testing restore on staging..."
    python scripts/cloud_backup.py --restore $(python scripts/cloud_backup.py --list | head -1 | awk '{print $1}')

    echo "[3/5] Verifying data integrity..."
    kubectl exec -n nebula-staging deployment/backend -- python -c "
from app.database.engine import connect
import asyncio
async def verify():
    db = await connect()
    result = await db.fetchone('SELECT COUNT(*) as count FROM users')
    print(f'Users restored: {result[\"count\"]}')
    await db.close()
asyncio.run(verify())
"

    echo "[4/5] Testing failover..."
    echo "  Stopping primary..."
    kubectl scale deployment/postgres-primary -n nebula-production --replicas=0
    echo "  Waiting for replica promotion..."
    sleep 30
    echo "  Verifying replica is serving..."
    curl -f https://api.nebula-search.com/health

    echo "[5/5] Restoring primary..."
    kubectl scale deployment/postgres-primary -n nebula-production --replicas=1
    echo "===== DR TEST COMPLETE ====="
}

# =============================================================================
# SECTION 7: SCALING PROCEDURES
# =============================================================================

scale_up() {
    echo "Scaling up for expected traffic increase..."
    kubectl scale deployment/backend -n nebula-production --replicas=8
    kubectl scale deployment/frontend -n nebula-production --replicas=6
    kubectl scale deployment/vector-worker -n nebula-production --replicas=4

    echo "Pre-warming cache..."
    kubectl exec -n nebula-production deployment/backend -- python -c "
from app.services.cache import cache_service
import asyncio
async def warm():
    await cache_service.connect()
    # Warm common queries
    queries = ['python', 'javascript', 'react', 'docker', 'kubernetes']
    for q in queries:
        await cache_service.get(f'search:{q}')
    print(f'Cache pre-warmed with {len(queries)} queries')
    await cache_service.close()
asyncio.run(warm())
"
}

scale_down() {
    echo "Scaling down for low traffic period..."
    kubectl scale deployment/backend -n nebula-production --replicas=2
    kubectl scale deployment/frontend -n nebula-production --replicas=2
    kubectl scale deployment/vector-worker -n nebula-production --replicas=1
}

# =============================================================================
# SECTION 8: MAINTENANCE PROCEDURES
# =============================================================================

# --- 8.1 Certificate Renewal ---
renew_certificates() {
    echo "Renewing TLS certificates..."
    kubectl delete certificate -n nebula-production nebula-tls
    sleep 5
    kubectl apply -f infrastructure/k8s/cluster-issuer.yaml
    kubectl apply -f infrastructure/k8s/certificate.yaml
    kubectl wait --for=condition=ready certificate/nebula-tls -n nebula-production --timeout=300s
}

# --- 8.2 Log Rotation ---
rotate_logs() {
    echo "Rotating logs..."
    kubectl exec -n nebula-production deployment/backend -- bash -c "
        mv /var/log/app.log /var/log/app.log.old && \
        kill -USR1 1
    "
}

# --- 8.3 Database Vacuum ---
vacuum_database() {
    echo "Running database VACUUM ANALYZE..."
    kubectl exec -n nebula-production deployment/backend -- python -c "
from app.database.engine import connect
import asyncio
async def vacuum():
    db = await connect()
    await db.execute('VACUUM ANALYZE')
    print('Database vacuum complete')
    await db.close()
asyncio.run(vacuum())
"
}

