# Nebula Search — Environment Configuration
# Copy to backend/.env and adjust values for your environment.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://nebula:nebula@localhost:5432/nebula

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GGUF_MODEL_PATH=
AI_PROVIDER=auto

# ── Search Backends ───────────────────────────────────────────────
BRAVE_API_KEY=
SERPAPI_KEY=

# ── App Settings ──────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=60
CACHE_TTL_SECONDS=300
STORAGE_ROOT=./storage

# ── Security ──────────────────────────────────────────────────────
ENCRYPTION_KEY=
ENABLE_CSRF=true
ENABLE_2FA=false
ENABLE_WEBAUTHN=false
ENABLE_RBAC=true
ENABLE_REFRESH_REUSE_DETECTION=true
ENABLE_AUDIT_LOGS=true
AUTH_COOKIE_MODE=true
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Rate Limiting (requests per minute) ──────────────────────────
SIGNUP_RATE_LIMIT=5
LOGIN_RATE_LIMIT=5
REFRESH_RATE_LIMIT=10
RATE_LIMIT_TIER_BASIC=30
RATE_LIMIT_TIER_PRO=120
RATE_LIMIT_TIER_ENTERPRISE=600
RATE_LIMIT_BURST_MULTIPLIER=2

# ── OAuth2 / SSO ─────────────────────────────────────────────────
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GITHUB_OAUTH2_CLIENT_ID=
GITHUB_OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_BASE_URI=http://localhost:8000/api/v1/auth/oauth2
OAUTH2_FRONTEND_REDIRECT_URI=http://localhost:5173/oauth/callback

# ── Security Headers ─────────────────────────────────────────────
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_CONNECT_SRC='self'
CSP_FONT_SRC='self'
CSP_FRAME_SRC='none'
CSP_OBJECT_SRC='none'
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
CROSS_ORIGIN_EMBEDDER_POLICY=require-corp
CROSS_ORIGIN_OPENER_POLICY=same-origin
CROSS_ORIGIN_RESOURCE_POLICY=same-origin

# ── Observability ────────────────────────────────────────────────
SENTRY_DSN=
OTEL_SERVICE_NAME=nebula-search
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# ── TOTP/2FA ──────────────────────────────────────────────────────
TOTP_ISSUER=Nebula Search
API_KEY_LENGTH=32
API_KEY_PREFIX=nb_
