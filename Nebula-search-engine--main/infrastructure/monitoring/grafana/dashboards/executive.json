      },
      "targets": [
        {
          "expr": "nebula_sla_compliance_ratio * 100",
          "legendFormat": "SLA Compliance",
          "interval": "5m"
        },
        {
          "expr": "99.9",
          "legendFormat": "SLA Target (99.9%)",
          "interval": "5m"
        }
      ]
