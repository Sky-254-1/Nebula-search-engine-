{
  "__inputs": [],
  "__requires": [],
  "title": "Nebula Executive Dashboard",
  "uid": "nebula-executive",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["nebula", "executive"],
  "schemaVersion": 38,
  "refresh": "5m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "System Health",
      "type": "row"
    },
    {
      "id": 2,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg by (service) (nebula_service_uptime_ratio) * 100",
          "legendFormat": "{{ service }}",
          "interval": "5m"
        }
      ]
    },
    {
      "id": 3,
      "title": "Overall Health Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "yellow", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nebula_health_score",
          "legendFormat": "Health Score",
          "interval": "5m"
        }
      ]
    },
    {
      "id": 4,
