{
  "__inputs": [],
  "__requires": [],
  "title": "Nebula Engineering Dashboard",
  "uid": "nebula-engineering",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["nebula", "engineering"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Traffic & Errors",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (method) (rate(nebula_http_requests_total[1m]))",
          "legendFormat": "{{ method }}",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_http_requests_total[1m]))",
          "legendFormat": "Total",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixed": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixed": "orange" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (endpoint, status) (rate(nebula_http_requests_total{status=~\"5..\"}[5m])) / sum by (endpoint) (rate(nebula_http_requests_total[5m])) * 100",
          "legendFormat": "{{ endpoint }} - 5xx",
          "interval": "15s"
        },
        {
          "expr": "sum by (endpoint, status) (rate(nebula_http_requests_total{status=~\"4..\"}[5m])) / sum by (endpoint) (rate(nebula_http_requests_total[5m])) * 100",
          "legendFormat": "{{ endpoint }} - 4xx",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Status Codes (1m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "429" },
            "properties": [{ "id": "color", "value": { "fixed": "purple" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(nebula_http_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_http_requests_total{status=\"429\"}[1m]))",
          "legendFormat": "429",
          "interval": "15s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "panels": [],
      "title": "Latency",
      "type": "row"
    },
    {
      "id": 6,
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixed": "red" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixed": "orange" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixed": "green" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(nebula_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nebula_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 7,
      "title": "Latency by Endpoint (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(nebula_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ endpoint }}",
          "interval": "15s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "panels": [],
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "id": 9,
      "title": "CPU Usage per Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))) * 100",
          "legendFormat": "{{ instance }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 10,
      "title": "Memory Usage per Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "{{ instance }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 11,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "read - {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "write - {{ instance }}",
          "interval": "15s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 12,
      "panels": [],
      "title": "Database",
      "type": "row"
    },
    {
      "id": 13,
      "title": "Database Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "active {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "active queries {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "idle connections {{ instance }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 14,
      "title": "Database Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched[5m])",
          "legendFormat": "fetched {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted[5m])",
          "legendFormat": "inserted {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated[5m])",
          "legendFormat": "updated {{ instance }}",
          "interval": "15s"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted[5m])",
          "legendFormat": "deleted {{ instance }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 15,
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 10737418240 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"nebula\"}",
          "legendFormat": "database size",
          "interval": "30s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 16,
      "panels": [],
      "title": "Redis Cache",
      "type": "row"
    },
    {
      "id": 17,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cache Hit Rate" },
            "properties": [{ "id": "color", "value": { "fixed": "green" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "Cache Hit Rate",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 18,
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "interval": "15s"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 19,
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients",
          "interval": "15s"
        },
        {
          "expr": "redis_blocked_clients",
          "legendFormat": "blocked",
          "interval": "15s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 20,
      "panels": [],
      "title": "Search Performance",
      "type": "row"
    },
    {
      "id": 21,
      "title": "Search Latency Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_search_duration_seconds_bucket{phase=\"web\"}[5m])))",
          "legendFormat": "web search",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_search_duration_seconds_bucket{phase=\"vector\"}[5m])))",
          "legendFormat": "vector search",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_search_duration_seconds_bucket{phase=\"orchestration\"}[5m])))",
          "legendFormat": "orchestration",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_search_duration_seconds_bucket{phase=\"reranking\"}[5m])))",
          "legendFormat": "reranking",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 22,
      "title": "Search Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nebula_search_requests_total{type=\"web\"}[5m]))",
          "legendFormat": "web",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_search_requests_total{type=\"vector\"}[5m]))",
          "legendFormat": "vector",
          "interval": "15s"
        },
        {
          "expr": "sum(rate(nebula_search_requests_total{type=\"orchestrated\"}[5m]))",
          "legendFormat": "orchestrated",
          "interval": "15s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 23,
      "panels": [],
      "title": "AI Providers",
      "type": "row"
    },
    {
      "id": 24,
      "title": "AI Provider Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
