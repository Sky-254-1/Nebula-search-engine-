# Database (SQLite file path or PostgreSQL URL)
DATABASE_URL=nebula.db
# Production example:
# DATABASE_URL=postgresql://nebula:nebula@localhost:5432/nebula

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_DAYS=30

# AI providers (auto | openai | ollama | gguf | duckduckgo)
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GGUF_MODEL_PATH=

# Search API keys
BRAVE_API_KEY=
SERPAPI_KEY=

# Redis (optional — enables distributed cache)
REDIS_URL=
CACHE_TTL_SECONDS=300

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Environment
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Storage root
STORAGE_ROOT=../storage
