# Database (SQLite path or PostgreSQL URL)
DATABASE_URL=nebula.db

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY_HOURS=24

# AI (optional — enables AI answers via OpenAI-compatible API)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Search API keys (optional — enables Brave/SerpAPI backends)
BRAVE_API_KEY=
SERPAPI_KEY=

# Redis (optional — for future caching)
REDIS_URL=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Environment: development | production | testing
APP_ENV=development

# CORS (comma-separated origins; use * only in local dev)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500
